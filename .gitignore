# ============================================================================
# HybridRAG v3 — .gitignore
# ============================================================================

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.egg-info/
dist/
build/

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# HybridRAG runtime data (regenerated, not source code)
data/
*.sqlite3
embeddings.f16.dat
embeddings_meta.json
logs/

# Model caches (downloaded at setup, not committed)
.model_cache/
.hf_cache/
.torch_cache/

# Archives
archive/
_archive_*/

# Machine-specific (regenerated by diagnostic / runtime)
config/system_profile.json
config/user_overrides.yaml

# Binary documents (not source code)
*.docx
*.xlsx
!docs/05_security/waiver_cheat_sheet_v5.xlsx

# Evaluation guides (local reference only)
Eval Guides*

# One-time utility scripts
cleanup_root.ps1
# Diagnostics outputs
api_diag_report.txt
api_diag_results.json
*.onnx
*.bin
*.safetensors

# SAFETY: Block bulk files
*.zip
*.7z
*.pdf
*.rar
*.tar.gz
_test*.yaml
*Copy*
!releases/*.zip

master_resource_guide.md

*.bak
_temp_*

# Evaluation output (runtime, not source)
eval_out/
scored_out/

# Pytest cache (never commit)
.pytest_cache/

# Runtime output (generated by troubleshooter, diagnostics)
output/

# Generated printable docs (run tools/generate_printable_docs.py to rebuild)
docs/_printable/

# Temp files
*.tmp

# GUI E2E test output (regenerated each run)
gui_e2e_report.json
eval_baseline_*.jsonl
eval_v2_*.jsonl

# Log files (runtime output, not source)
*.log

# Diagnostic run artifacts (generated, not source)
claude_diag/
claude_diag_gui/
claude_diag_run/
claude_diag_run_tmp_gui_e2e.json
runtime_traces_after.json
demo_transcript.json
gui_e2e_report_mock.json

# Personal reference guides (contain tool-specific names, not for repo)
docs/06_guides/

# USB installer staging output (built at runtime, not source)
USB Installer Research/_staging/
.tmp_*/
